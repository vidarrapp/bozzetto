{
  "name": "bozzetto",
  "version": "0.1.0",
  "description": "Web-based 3D viewer for sculpt timelapses: per-frame decimated meshes with real relighting, shadows, material modes, and DCC-style camera control.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "gen:sample": "node scripts/generate-sample.mjs",
    "predev": "node scripts/generate-sample.mjs",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "typecheck:functions": "tsc -p tsconfig.functions.json",
    "prebuild": "node scripts/generate-sample.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "cf:dev": "npm run build && wrangler pages dev",
    "db:migrate:local": "wrangler d1 migrations apply bozzetto --local",
    "db:migrate": "wrangler d1 migrations apply bozzetto --remote"
  },
  "dependencies": {
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "@types/three": "^0.160.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wrangler": "^3.84.0"
  }
}
