# Cloudflare Pages headers. Hashed Vite bundles in /assets/* are already
# immutable via the framework; these are the stable-named heavy assets, cached
# so repeat visits don't re-download them. (First load is unaffected — for the
# HDRs, 1k exports are the win there.)

/assets/env/*
  Cache-Control: public, max-age=604800

/assets/matcaps/*
  Cache-Control: public, max-age=604800

/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable
